# ============================================
# PostgreSQL 数据库配置
# ============================================
PG_CONNECTION_STRING=postgresql://postgres:postgres@127.0.0.1:5432/agentdb

# ============================================
# DashScope API 配置
# 敏感密钥请写在 .env.local（已 git 忽略），会覆盖下方占位项
# ============================================
DASHSCOPE_API_KEY=your-api-key-here
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_MODEL=deepseek-v3.2-exp
LLM_TEMPERATURE=0.7
REQUEST_TIMEOUT=60000
